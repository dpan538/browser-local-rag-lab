{
  "name": "browser-local-rag-lab",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Reproducible research lab for browser-local small-model RAG with WebGPU/WebLLM runtimes, evidence-packet compression, latency benchmarks, and rights-aware archive fixtures.",
  "scripts": {
    "gold:build": "node scripts/build_gold_fixture.mjs",
    "gold:sufficiency": "node scripts/evaluate_retrieval_sufficiency.mjs",
    "gold:sufficiency:200": "node scripts/evaluate_retrieval_sufficiency.mjs --queries fixtures/expansion/round02_200/queries.jsonl --labels fixtures/expansion/round02_200/labels.jsonl --records fixtures/expansion/round02_200/records.jsonl --json-out reports/retrieval_sufficiency_200.json --csv-out reports/retrieval_sufficiency_200.csv --md-out reports/RETRIEVAL_SUFFICIENCY_200.md",
    "evidence:health": "node scripts/evidence_health_check.mjs",
    "evidence:health:strict": "node scripts/evidence_health_check.mjs --strict",
    "evidence:value": "node scripts/evidence_value_check.mjs",
    "evidence:value:strict": "node scripts/evidence_value_check.mjs --strict",
    "method:context": "node scripts/validate_method_context.mjs",
    "method:context:strict": "node scripts/validate_method_context.mjs --strict",
    "labels:consistency": "node scripts/label_consistency_check.mjs",
    "labels:consistency:strict": "node scripts/label_consistency_check.mjs --strict",
    "audit:labels": "node scripts/audit_gold_labels.mjs",
    "audit:labels:strict": "node scripts/audit_gold_labels.mjs --strict",
    "audit:quality": "node scripts/quality_metrics.mjs",
    "audit:full": "node scripts/run_full_pipeline.mjs",
    "retrieval:coverage": "node scripts/retrieval_coverage.mjs",
    "generation:contract": "node scripts/validate_generation_contract.mjs",
    "generation:contract:v2": "node scripts/validate_generation_contract_v2.mjs",
    "webllm:import": "node scripts/import_webllm_round.mjs",
    "webllm:gate": "node scripts/gate_webllm_round.mjs",
    "webllm:gate:pilot50": "node scripts/gate_webllm_round.mjs --round-json reports/webllm_round_02_200_pilot50.json --answers reports/webllm_round_02_200_pilot50_answers.jsonl --expected 50 --json-out reports/webllm_round_02_200_pilot50_gate.json --md-out reports/WEBLLM_ROUND_02_200_PILOT50_GATE.md --strict",
    "webllm:gate:200": "node scripts/gate_webllm_round.mjs --round-json reports/webllm_round_02_200.json --answers reports/webllm_round_02_200_answers.jsonl --expected 200 --json-out reports/webllm_round_02_200_gate.json --md-out reports/WEBLLM_ROUND_02_200_GATE.md --strict",
    "round2:preflight": "node scripts/preflight_round02.mjs",
    "round2:preflight:200": "node scripts/preflight_round02.mjs --queries fixtures/expansion/round02_200/queries.jsonl --labels fixtures/expansion/round02_200/labels.jsonl --records fixtures/expansion/round02_200/records.jsonl --retrieval reports/retrieval_sufficiency_200.json --json-out reports/round02_200_preflight.json --md-out reports/ROUND_02_200_DESIGN.md --round-id round02_200",
    "round2:review-sheet": "node scripts/generate_review_sheet.mjs",
    "round2:review-sheet:200": "node scripts/generate_review_sheet.mjs --queries fixtures/expansion/round02_200/queries.jsonl --labels fixtures/expansion/round02_200/labels.jsonl --records fixtures/expansion/round02_200/records.jsonl --answers reports/webllm_round_02_200_answers.jsonl --json-out reports/quality_review_sheet_round_02_200.json --md-out reports/QUALITY_REVIEW_SHEET_ROUND_02_200.md",
    "round2:scale-readiness": "node scripts/scale_readiness.mjs",
    "audit:labels:200": "node scripts/audit_gold_labels.mjs --queries fixtures/expansion/round02_200/queries.jsonl --labels fixtures/expansion/round02_200/labels.jsonl --records fixtures/expansion/round02_200/records.jsonl --report reports/GOLD_LABEL_AUDIT_200.md --json reports/gold_label_audit_200.json",
    "audit:regression": "node scripts/regression_test.mjs",
    "labels:change-log": "node scripts/label_change_log.mjs",
    "labels:promote": "node scripts/promote_stable_labels.mjs",
    "labels:suggest": "node scripts/suggest_label.mjs",
    "queries:split-batches": "node scripts/split_queries_to_batches.mjs",
    "expand:round2:200": "node scripts/build_round02_200_expansion.mjs",
    "review:fixture": "node scripts/build_review_fixture.mjs",
    "review:apply": "node scripts/apply_review_decisions.mjs",
    "records:validate-new": "node scripts/validate_new_records.mjs",
    "audit:anomalies": "node scripts/detect_anomalies.mjs",
    "scaffold:intent": "node scripts/scaffold_intent.mjs",
    "execute:round1": "node scripts/run_execution_round_01.mjs",
    "benchmark": "node scripts/run_benchmark.mjs",
    "analyze": "node scripts/analyze_results.mjs",
    "serve": "python3 -m http.server 4177 --bind 127.0.0.1"
  },
  "keywords": [
    "browser-local-rag",
    "webgpu",
    "webllm",
    "small-language-models",
    "qwen",
    "onnx-runtime",
    "transformers-js",
    "latency-benchmark",
    "evidence-compression",
    "digital-archives"
  ],
  "license": "MIT"
}
