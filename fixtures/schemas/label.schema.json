{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/dpan538/browser-local-rag-lab/fixtures/schemas/label.schema.json",
  "title": "Browser Local RAG Gold Label",
  "type": "object",
  "required": [
    "query_id",
    "intent",
    "gold_lane",
    "sufficient_context",
    "refusal_expected",
    "gold_evidence_ids",
    "required_fields",
    "must_not_invent_fields",
    "allowed_guidance",
    "gold_answer_slots",
    "review_state"
  ],
  "properties": {
    "query_id": { "type": "string" },
    "intent": { "type": "string" },
    "gold_lane": {
      "type": "string",
      "enum": ["help", "fast_answer", "research_answer", "source_rights", "refusal_more_context"]
    },
    "sufficient_context": { "type": "boolean" },
    "refusal_expected": { "type": "boolean" },
    "gold_evidence_ids": { "type": "array", "items": { "type": "string" } },
    "required_fields": { "type": "array", "items": { "type": "string" } },
    "must_not_invent_fields": { "type": "array", "items": { "type": "string" } },
    "allowed_guidance": { "type": "boolean" },
    "gold_answer_slots": { "type": "array", "items": { "type": "string" } },
    "review_state": {
      "type": "string",
      "enum": ["seed_auto_needs_human_review", "human_reviewed"]
    },
    "notes": { "type": "string" }
  },
  "additionalProperties": false
}
